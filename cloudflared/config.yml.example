# Cloudflare Tunnel Config
# Generated by: ./scripts/setup-cloudflare-tunnel.sh
#
# Each "hostname" entry routes a subdomain to a specific container.
# Cloudflare handles SSL automatically — no certificates to manage.
#
# After adding DNS records in Cloudflare dashboard (CNAME → <tunnel-id>.cfargotunnel.com),
# traffic flows: Internet → Cloudflare → this tunnel → container

tunnel: YOUR-TUNNEL-ID-HERE
credentials-file: /etc/cloudflared/YOUR-TUNNEL-ID-HERE.json

ingress:
  - hostname: plex.yourdomain.com
    service: http://localhost:32400
    # Plex uses network_mode: host, so we reach it via localhost

  - hostname: audiobooks.yourdomain.com
    service: http://audiobookshelf:80

  - hostname: files.yourdomain.com
    service: http://filebrowser:80

  - hostname: home.yourdomain.com
    service: http://homepage:3000

  # Required catch-all — must be last
  - service: http_status:404
