# ============================================================
# Plexathon - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER share your .env file — it contains passwords.
# ============================================================

# Your timezone (find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=America/New_York

# Path to your external drive on the Mac mini
# Plug in the drive, then find its name in Finder under "Locations"
# It will be mounted at /Volumes/<drive name>
# Example: /Volumes/MediaDrive
MEDIA_PATH=/Volumes/MediaDrive

# ---- Remote Access ----
# Your domain name (e.g. myfamily.com)
# Leave blank if you only want local network access
DOMAIN=yourdomain.com

# ---- ProtonVPN (for torrent traffic) ----
# WireGuard private key from ProtonVPN:
#   1. Go to proton.me → VPN → Downloads → WireGuard configuration
#   2. Generate a config for your chosen server
#   3. Copy the "Private key" line from the [Interface] section
PROTONVPN_PRIVATE_KEY=your_wireguard_private_key_here

# ProtonVPN server to connect through — use the display name shown in the ProtonVPN app
# Example: US-NJ#65
PROTONVPN_SERVER=US-NJ#65
