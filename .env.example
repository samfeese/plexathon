# ============================================================
# Plexathon - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER share your .env file — it contains passwords.
# ============================================================

# Your timezone (find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=America/New_York

# Where your media files will be accessible on this Mac
# (The setup script mounts your Windows share here automatically)
MEDIA_PATH=/Volumes/Media

# ---- Windows Laptop File Share ----
# The IP address of the Windows laptop on your home network
# (Find it on Windows: Settings → Network → Properties → IPv4 address)
SMB_SERVER=192.168.1.100

# The name of the shared folder on Windows
# (Whatever you named it when you set up the share)
SMB_SHARE=Media

# Windows login credentials
SMB_USERNAME=your_windows_username
SMB_PASSWORD=your_windows_password

# ---- Remote Access ----
# Your domain name (e.g. myfamily.com)
# Leave blank if you only want local network access
DOMAIN=yourdomain.com

# ---- Plex ----
# Your Plex claim token — get it at: https://www.plex.tv/claim/
# (Log in to plex.tv, visit that link, copy the token — it expires in 4 minutes)
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxxx
